APP_NAME="Newscast Navigator API"
ENVIRONMENT="development"
DATABASE_URL="postgresql+psycopg://newscast:newscast@db:5432/newscast"
# Допустимы оба формата:
# 1) CSV: "http://localhost:5173,http://127.0.0.1:5173"
# 2) JSON: ["http://localhost:5173","http://127.0.0.1:5173"]
CORS_ORIGINS="http://localhost:5173,http://127.0.0.1:5173,http://192.168.2.200:5173"
AUTO_CREATE_SCHEMA=true
SEED_DEMO_DATA=true
SESSION_SECRET="change-me-for-production"
