APP_NAME="Newscast Navigator API"
ENVIRONMENT="development"
DATABASE_URL="sqlite:///~/.local/share/newscast-navigator/dev/dev.db"
# Допустимы оба формата:
# 1) CSV: "http://localhost:5173,http://127.0.0.1:5173"
# 2) JSON: ["http://localhost:5173","http://127.0.0.1:5173"]
CORS_ORIGINS="http://127.0.0.1:5173,http://localhost:5173"
SEED_DEMO_DATA=true
SECRET_KEY="change-me-for-production"
STORAGE_PATH="~/.local/share/newscast-navigator/dev/storage"
EXPORT_PATH="~/.local/share/newscast-navigator/dev/exports"
MAX_UPLOAD_SIZE_MB=512
ALLOWED_UPLOAD_EXTENSIONS=".mp4,.mov,.mxf,.mp3,.wav,.m4a,.aac,.jpg,.jpeg,.png,.webp,.pdf,.docx,.txt"
