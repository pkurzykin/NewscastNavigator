POSTGRES_DB=newscast_dev
POSTGRES_USER=newscast
POSTGRES_PASSWORD=change-this-dev-db-password

APP_NAME=Newscast Navigator API
ENVIRONMENT=development
DATABASE_URL=postgresql+psycopg://newscast:change-this-dev-db-password@db:5432/newscast_dev
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173
SECRET_KEY=change-this-dev-secret
SEED_DEMO_DATA=true
STORAGE_PATH=/app/storage
EXPORT_PATH=/app/exports
MAX_UPLOAD_SIZE_MB=512
ALLOWED_UPLOAD_EXTENSIONS=.mp4,.mov,.mxf,.mp3,.wav,.m4a,.aac,.jpg,.jpeg,.png,.webp,.pdf,.docx,.txt

VITE_API_BASE_URL=
VITE_PROXY_TARGET=http://backend:8000

POSTGRES_PORT=5433
BACKEND_PORT=8100
FRONTEND_PORT=5173
