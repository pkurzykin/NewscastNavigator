POSTGRES_DB=newscast
POSTGRES_USER=newscast
POSTGRES_PASSWORD=change-this-db-password
DATABASE_URL=postgresql+psycopg://newscast:change-this-db-password@db:5432/newscast
SECRET_KEY=change-this-session-secret
STORAGE_PATH=/app/storage
EXPORT_PATH=/app/exports

# Пока на сервере уже работает какая-то версия проекта, держим web-stack
# на локальном loopback-порту и переводим на публичный порт только после аудита.
NGINX_BIND_HOST=127.0.0.1
NGINX_HTTP_PORT=8088

# Для production за reverse proxy обычно достаточно localhost и доменного имени.
# Для CEP/CaptionPanels one-click fetch также нужен Origin: null.
CORS_ORIGINS=http://127.0.0.1:8088,http://localhost:8088,null

# Если frontend и backend живут за одним reverse proxy, оставляем пустым.
FRONTEND_VITE_API_BASE_URL=

MAX_UPLOAD_SIZE_MB=512
ALLOWED_UPLOAD_EXTENSIONS=.mp4,.mov,.mxf,.mp3,.wav,.m4a,.aac,.jpg,.jpeg,.png,.webp,.pdf,.docx,.txt
